# ─────────────────────────────────────────────────────────────────────────────
# AI Trip Planner — Environment Variables
# Rename this file to .env and fill in your keys
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED: Google Gemini API Key
# Get free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL but recommended: OpenWeatherMap API Key (free tier)
# Register at: https://openweathermap.org/api
# Free tier: 1000 calls/day, current weather + 5-day forecast
OPENWEATHER_API_KEY=your_openweather_key_here

# OPTIONAL: Google Places API Key (for real hotel search)
# Enable "Places API" at: https://console.cloud.google.com
# Free tier: $200/month credit
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# OPTIONAL: Default departure city (pre-fills the UI)
DEFAULT_ORIGIN=Mumbai
